{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Datrina The Lenswright",
  "version": "0.1.0",
  "identifier": "app.datrina.desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": false,
    "targets": ["deb", "rpm", "msi", "dmg", "appimage"],
    "category": "Productivity",
    "copyright": "2026 Mikhail Privalov <n5250@yandex.com>",
    "licenseFile": "../LICENSE.md",
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "13.0",
      "signingIdentity": null,
      "entitlements": null
    },
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Datrina The Lenswright",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "fullscreen": false,
        "visible": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "connect-src": "'self' http://localhost:* https://*",
        "img-src": "'self' data: https:",
        "style-src": "'self' 'unsafe-inline'",
        "script-src": "'self' 'unsafe-eval'",
        "font-src": "'self' data:"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": "^https?://.*"
    }
  }
}
